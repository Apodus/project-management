{
  "name": "@pm/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "openapi:export": "tsx src/scripts/export-openapi.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@hono/zod-openapi": "^1.4.0",
    "@pm/shared": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.19",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
