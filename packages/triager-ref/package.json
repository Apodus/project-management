{
  "name": "@urtela/pm-triager",
  "version": "0.1.0",
  "description": "Reference triager daemon for the PM notes inbox — polls open notes for the watched project(s) and (in later phases) assesses each oldest-first, recording a triage decision in the side-log. The T2·P2 scaffold wires the poll/seed loop end-to-end with a pure-log STUB decide() that mutates nothing; P3 adds the assessment brain, P4 the decision execution. One process per watched project. Ships OFF.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/Apodus/project-management#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apodus/project-management.git",
    "directory": "packages/triager-ref"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pm-triager": "./dist/bundle/pm-triager.mjs"
  },
  "files": [
    "dist/bundle/*.mjs",
    "README.md"
  ],
  "scripts": {
    "gen-version": "node scripts/gen-version.mjs",
    "prebuild": "node scripts/gen-version.mjs",
    "build": "tsc --build && node scripts/add-shebang.mjs",
    "bundle": "node scripts/bundle.mjs",
    "predev": "node scripts/gen-version.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prelint": "node scripts/gen-version.mjs",
    "lint": "eslint src/",
    "pretypecheck": "node scripts/gen-version.mjs",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/gen-version.mjs",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build && pnpm run bundle"
  },
  "devDependencies": {
    "@pm/shared": "workspace:*",
    "@types/node": "^22",
    "commander": "^12.1.0",
    "esbuild": "^0.28.0",
    "pino": "^9.5.0",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
