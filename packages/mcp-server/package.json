{
  "name": "@apodus/pm-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for the Human-AI Collaborative Project Management system — lets Claude (or any MCP-compatible agent) manage projects, proposals, tasks, and the merge train over the PM REST API.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/Apodus/project-management#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apodus/project-management.git",
    "directory": "packages/mcp-server"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pm-mcp-server": "./dist/bundle/pm-mcp-server.mjs"
  },
  "files": [
    "dist/bundle/*.mjs",
    "README.md"
  ],
  "scripts": {
    "gen-version": "node scripts/gen-version.mjs",
    "prebuild": "node scripts/gen-version.mjs",
    "build": "tsc --build && node scripts/bundle.mjs",
    "predev": "node scripts/gen-version.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prelint": "node scripts/gen-version.mjs",
    "lint": "eslint src/",
    "pretypecheck": "node scripts/gen-version.mjs",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/gen-version.mjs",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pm/shared": "workspace:*",
    "@types/node": "^22",
    "esbuild": "^0.28.0",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "zod": "^3.25.76"
  }
}
