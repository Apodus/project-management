{
  "name": "@pm/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pm-mcp-server": "./dist/bundle/pm-mcp-server.mjs"
  },
  "scripts": {
    "gen-version": "node scripts/gen-version.mjs",
    "prebuild": "node scripts/gen-version.mjs",
    "build": "tsc --build && node scripts/bundle.mjs",
    "predev": "node scripts/gen-version.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prelint": "node scripts/gen-version.mjs",
    "lint": "eslint src/",
    "pretypecheck": "node scripts/gen-version.mjs",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/gen-version.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pm/shared": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.28.0",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
