{
  "name": "@urtela/pm-responder",
  "version": "0.1.0",
  "description": "Reference responder daemon for the PM escalation channel — polls open escalations for the watched project(s) and claims each via acknowledge (the C1 one-active-responder gate). The skeleton (C3 P1) only claims; P2 adds the headless claude spawn that reads the thread, answers, and resolves. One process per watched project.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/Apodus/project-management#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Apodus/project-management.git",
    "directory": "packages/responder-ref"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pm-responder": "./dist/bundle/pm-responder.mjs"
  },
  "files": [
    "dist/bundle/*.mjs",
    "README.md"
  ],
  "scripts": {
    "gen-version": "node scripts/gen-version.mjs",
    "prebuild": "node scripts/gen-version.mjs",
    "build": "tsc --build && node scripts/add-shebang.mjs",
    "bundle": "node scripts/bundle.mjs",
    "predev": "node scripts/gen-version.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prelint": "node scripts/gen-version.mjs",
    "lint": "eslint src/",
    "pretypecheck": "node scripts/gen-version.mjs",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/gen-version.mjs",
    "test": "vitest run",
    "prepublishOnly": "pnpm run build && pnpm run bundle"
  },
  "devDependencies": {
    "@pm/shared": "workspace:*",
    "@types/node": "^22",
    "commander": "^12.1.0",
    "esbuild": "^0.28.0",
    "pino": "^9.5.0",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
