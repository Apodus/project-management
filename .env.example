# Server
PM_PORT=3000
PM_HOST=127.0.0.1
PM_DB_PATH=./data/pm.db
PM_SESSION_SECRET=change-me-to-a-random-string
PM_LOG_LEVEL=info
NODE_ENV=production

# Claim lease engine (C2) — all optional; defaults hold the shipped posture
# (shadow mode, 30m TTL, 24h grace). Leave commented unless tuning.
# PM_LEASE_MODE=shadow       # off | shadow | on  (on is C1-gated)
# PM_LEASE_TTL_SEC=1800      # lease TTL (seconds) before lapse
# PM_LEASE_GRACE_SEC=86400   # reclaim grace (seconds) beyond TTL

# MCP Server (configure in Claude's MCP settings)
PM_API_URL=http://localhost:3000
PM_API_TOKEN=your-ai-agent-api-token
