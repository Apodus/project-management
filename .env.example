# Server
PM_PORT=3000
PM_HOST=127.0.0.1
PM_DB_PATH=./data/pm.db
PM_LOG_LEVEL=info
NODE_ENV=production
# PM_WEB_DIST_PATH=/abs/path/to/packages/web/dist   # override the auto-resolved web dist dir (production SPA serving)

# Auth has NO signing secret to configure: sessions and API tokens are opaque
# random tokens stored bcrypt-hashed server-side (sessions ride an httpOnly
# `pm_session` cookie; API tokens go in the Authorization header).

# Agent pool
# PM_POOL_SECRET=your-pool-secret   # server: auto-creates the "default" pool on first claim; MCP: auto-claims an agent identity (alternative to PM_API_TOKEN)

# Claim lease engine (C2) — all optional; defaults hold the shipped posture
# (shadow mode, 30m TTL, 24h grace). Leave commented unless tuning.
# PM_LEASE_MODE=shadow       # off | shadow | on  (on is C1-gated)
# PM_LEASE_TTL_SEC=1800      # lease TTL (seconds) before lapse
# PM_LEASE_GRACE_SEC=86400   # reclaim grace (seconds) beyond TTL

# MCP Server (configure in Claude's MCP settings)
PM_API_URL=http://localhost:3000
PM_API_TOKEN=your-ai-agent-api-token
# PM_POOL_NAME=default     # pool to auto-claim from when PM_POOL_SECRET is set (defaults to "default")
# PM_WORKER_KEY=worker-1   # stable per-worker identity; distinct per worker; pairs with pool secret
